# GEMINI_API_KEY / VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# VITE_* variables are auto-exposed to the frontend by Vite.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Veo 视频（与 Gemini 共用 GEMINI_API_KEY；需在 Google AI Studio 开通 Veo 计费）
# 默认标准版（文案+参考图）：VEO_MODEL=veo-3.1-generate-preview
# 若仅用 Fast、不传参考图：VEO_MODEL=veo-3.1-fast-generate-preview 且可设 VITE_VEO_MODEL 同名以便前端校验一致
# VEO_ASPECT_RATIO=9:16
# 仅文案、不生成视频：VITE_ENABLE_VEO=false

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
